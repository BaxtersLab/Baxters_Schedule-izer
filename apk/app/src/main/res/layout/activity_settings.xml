<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_native_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Native engine state: unknown"
        android:paddingBottom="12dp" />

    <Button
        android:id="@+id/btn_enable_native"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable RemoteDexter Native Engine" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:background="#33000000" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Budget Blaster receipt endpoint"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="POST /receipt URL on the homelab PC (e.g. http://192.168.1.100:8082/receipt)"
        android:textSize="12sp"
        android:paddingBottom="8dp" />

    <EditText
        android:id="@+id/et_budget_blaster_endpoint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textUri"
        android:hint="http://192.168.1.100:8082/receipt" />

    <Button
        android:id="@+id/btn_save_endpoint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Save endpoint" />

</LinearLayout>
